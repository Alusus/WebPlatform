اشمل "مـتم/نـظام"؛
اشمل "مـتم/سندات"؛
اشمل "مـتم/مـصفوفة"؛
اشمل "مـتم/نـص"؛
اشمل "مـتم/طـرفية"؛
اشمل "مغلفة"؛
اشمل "بـناء"؛
اشمل "مـحا"؛
مـحا.اشمل_ملف("Alusus/WebPlatform"، "مـنصة_ويب.أسس")؛
مـحا.اشمل_ملف("Alusus/Json"، "جـيسون.أسس")؛
مـحا.اشمل_ملف("Alusus/Threading"، "تـوازي.أسس")؛

استخدم مـتم؛
استخدم مـنصة_ويب؛

صنف مـدخل_نصي {
    @حقنة عرف مركب: مـركب؛

    عرف قد_تم_الإدخال: مغلفة (نـص)؛
    عرف مدخل_النص: سـندنا[مـدخل_نص]؛

    عملية هذا.العرض = سـندنا[مـسافة] {
        هذا.المشهد.الطراز.العرض = قيمة؛
        أرجع قيمة؛
    }

    عملية هذا.الطول = سـندنا[مـسافة] {
        هذا.المشهد.الطراز.الطول = قيمة؛
        أرجع قيمة؛
    }

    عملية هذا~هيئ() {
        عرف الكائن: سند[هذا_الصنف](هذا)؛

        هذا.المشهد = صـندوق({}).{
            الطراز.{
                الإظهار = إظـهار._مرن_؛
                النسق = نـسق._سطر_؛
                ملء_السطر = مـلء_سطر._مسافة_بينية_؛
                الفجوة = مـسافة.بكسلات(5)؛
                الطول = مـسافة.بكسلات(40)؛
            }؛
            أضف_فروع({
                مـدخل_نص().{
                    الكائن.مدخل_النص = هذا؛
                    الطراز.{
                        الطول = مـسافة.مئوي(100)؛
                        المرونة = مـرونة(1)؛
                        حجم_الخط = مـسافة.نقاط(12.0)؛
                    }؛
                    عند_انتهاء_الكبسة.اربط(مغلفة (ضبيطة: سند[مـدخل_نص]، الحمولة: سند[نـص]) {
                        إذا الحمولة == "Shift+Enter" {
                            عرف بيانات_جديده: نـص = ضبيطة.هات_النص().شذب()؛
                            ضبيطة.حدد_النص(نـص())؛
                            إذا ليس الكائن.قد_تم_الإدخال.أهو_عدم() الكائن.قد_تم_الإدخال(بيانات_جديده)؛
                        }
                    })؛
                }،
                الـزر(نـص("أرسل")).{
                    الطراز.{
                        الطول = مـسافة.مئوي(100)؛
                        العرض = مـسافة.نقاط(50)؛
                        حجم_الخط = مـسافة.نقاط(16.0)؛
                        ملء_السطر = مـلء_سطر._وسط_؛
                    }؛
                    عند_الضغط.اربط(مغلفة (ضبيطة: سند[ضـبيطة]، الحمولة: سند[صحيح]) {
                        عرف بيانات_جديده: نـص = الكائن.مدخل_النص.هات_النص().شذب()؛
                        الكائن.مدخل_النص.حدد_النص(نـص())؛
                        إذا ليس الكائن.قد_تم_الإدخال.أهو_عدم() الكائن.قد_تم_الإدخال(بيانات_جديده)؛
                    })؛
                }
            })؛
        }؛
    }

    عملية هذا_الصنف(): سـندنا[مـدخل_نصي] {
        أرجع سـندنا[مـدخل_نصي].أنشئ()؛
    }
}

@منفذ_مرئي["/"]
@عنوان["مثال منصة ويب - المركبات"]
دالة الرئيسية {
    عرف الكتابة: سـندنا[كـتابة]؛

    نـافذة.النموذج.الطراز.{
        الحشوة = مـسافة4.نقاط(0)؛
        الهامش = مـسافة4.نقاط(0)؛
        الاتجاه = اتـجاه._من_اليمين_؛
    }؛
    نـافذة.النموذج.حدد_المشهد(صـندوق().{
        الطراز.{
            الإظهار = إظـهار._مرن_؛
            النسق = نـسق._عمود_؛
            أقصى_عرض = مـسافة.بكسلات(400)؛
            الفجوة = مـسافة.بكسلات(20)؛
            الحشوة = مـسافة4.بكسلات(20)؛
        }؛
        أضف_فروع({
            مـدخل_نصي().{
                قد_تم_الإدخال = مغلفة (الكتابة: كسند)&(نص: نـص) {
                    الكتابة.النص = نص؛
                }
            }،
            مـدخل_نصي().{
                الطراز.{
                    الخلفية = خـلفية(لـون(0، 100، 100))؛
                    الحشوة = مـسافة4.بكسلات(5)؛
                }؛
                قد_تم_الإدخال = مغلفة (الكتابة: كسند)&(نص: نـص) {
                    الكتابة.النص = نص؛
                }
            }،
            كـتابة().{
                الكتابة = هذا؛
            }
        })؛
    })؛

    نفذ_حلقة_معالجة_الأحداث()؛
}


